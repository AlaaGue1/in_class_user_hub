<% if @users.any? %>
<table class="mytable">
  <thead>
    <tr>
      <td>ID</td>
      <td>Name</td>
      <td>Email</td>
      <td>Created At</td>
      <td>Updated At</td>
      <td>Select</td>
      <td>Update</td>
      <td>Delete</td>
    </tr>
  </thead>
  <tbody>
    <% @users.each do |user| %>
      <tr>
        <td><%= user.id %></td>
        <td><%= user.name %></td>
        <td><%= user.email %></td>
        <td><%= user.created_at %></td>
        <td><%= user.updated_at %></td>
        <td><%= link_to "Select", user_path(user.id) %></td>
        <td><%= link_to "Edit", edit_user_path(user.id) %></td>
        <td><%= button_to "Delete", user_path(user.id), method: :delete %></td>
      </tr>
    <% end %>
  </tbody>
  <tfoot>
    <tr>
      <td colspan="8">End of User List :)</td>
    </tr>
  </tfoot>
</table>
<% else %>
  <div class="form"> No users found. :(</div>
<% end %>

